	TITLE Munching Squares - Knight TV version

;This version uses the X xor Y <= T formulation.  For every T, we
;only add the pixels for which X xor Y = T.  Rearranging the equation,
;we get X = Y xor T.  So for each T we can just iterate across Y and
;plot the pixel at the computed X.

A=1
B=2
T=10
X=11
X1=12
Y=13
P=17

.VECTOR PDL(PDLLEN==20)

GO:	MOVE P,[-PDLLEN,,PDL-1]
	PUSHJ P,TVINIT
	MOVEI T,0		;Loop for each T < 512.
LOOP:	PUSHJ P,DRAW
	MOVEI A,2		;Give the CPU a little rest.
	.SLEEP A,
	ADDI T,1		;Next T.
	ANDI T,511.
	JRST LOOP

;Update the display for the current value of T.
DRAW:	MOVEI Y,453.		;Loop for each row on the display.
DRAW1:	MOVE X,Y
	XOR X,T			;Compute X = Y xor T.
	SETZ X1,
	CIRC X,-5		;Get address offset in X and pixel offset inside word in X1.
	MOVE A,XTAB(X1)		;Get pixel mask.
	MOVEM A,@YTAB(Y)	;Draw the pixel in the frame buffer.
	SOJGE Y,DRAW1
	POPJ P,

;Initialize and clear the TV display.
TVINIT:	MOVE A,[-10,,TVPAG]	;Map frame buffer pages into memory.
	MOVEI B,0
	.CALL [ SETZ
		'CORBLK
		MOVEI %CBWRT
		MOVEI %JSELF
		MOVE A
		MOVEI %JSTVB
		SETZ B ]
	 .VALUE [ASCIZ /:Must run on a TV.

:KILL¯/]
	.SUSET [.RTVCREG,,A]	;Set TV ALU to MOVEM mode.
	MOVEI B,17
	DPB B,[341000,,A]
	.SUSET [.STVCREG,,A]
	SETZ TVBUF		;Clear frame buffer.
	MOVE B,[TVBUF,,TVBUF+1]
	BLT B,TVBUF+<10*2000>-1
	MOVEI B,6		;Set ALU to XOR mode.
	DPB B,[341000,,A]
	.SUSET [.STVCREG,,A]
	POPJ P,

;For each X offset inside a word, this is the mask to draw a pixel.
;The .RPCNT computation is to reverse the order of bits due to the use of CIRC.
XTAB:
REPEAT 32.,[SETZ_-<<<.RPCNT&1>_4>+<<.RPCNT&2>_2>+<.RPCNT&4>+<<.RPCNT&10>_-2>+<<.RPCNT&20>_-4>>
]

;For each Y, this is an indirect address into the frame buffer plus
;the X offset.  The buffer is 576 pixels wide, with 32 pixels per
;word.
YTAB:
REPEAT 454.,[TVBUF+<576./32.>*.RPCNT(X)
]

TVPAG=<.+1777>/2000
TVBUF=TVPAG_10.

END GO
